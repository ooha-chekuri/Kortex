# KORTEX CONFIGURATION

# --- LLM PROVIDER ---
# Options: gemini, openai, ollama, groq
KORTEX_LLM_PROVIDER=gemini

# --- API KEYS ---
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_key_here
OPENAI_API_KEY=your_openai_api_key_here

# --- MODELS ---
KORTEX_LLM_MODEL=gemini-2.5-flash
# For Groq: llama3-70b-8192 or mixtral-8x7b-32768
KORTEX_GROQ_MODEL=llama3-70b-8192

# --- OLLAMA (Local) ---
OLLAMA_HOST=http://localhost:11434
